    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.8.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@vitest/browser-playwright": "^4.1.4",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "eslint": "^10.2.0",
