    "svelte-check": "^4.4.6",
    "sveltekit-superforms": "^2.30.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
